{
  "name": "@skyphusion/sidvicious-exe",
  "version": "0.2.3",
  "private": false,
  "type": "module",
  "description": "SidVicious_exe -- punk rock Discord roadie for search and image generation via Cloudflare",
  "homepage": "https://github.com/skyphusion-labs/SidVicious_exe",
  "repository": {
    "type": "git",
    "url": "https://github.com/skyphusion-labs/SidVicious_exe.git"
  },
  "keywords": [
    "discord-bot",
    "cloudflare-workers",
    "llm",
    "web-search",
    "image-generation",
    "workers-ai",
    "self-hosted"
  ],
  "scripts": {
    "roadie": "node --env-file-if-exists=.env bot.mjs",
    "bot": "node --env-file-if-exists=.env bot.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112",
    "discord.js": "^14"
  },
  "overrides": {
    "undici": "6.27.0"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@vitest/coverage-istanbul": "^4.1.10",
    "vitest": "^4.1.9"
  },
  "license": "AGPL-3.0-only",
  "bin": {
    "sidvicious": "./bot.mjs"
  },
  "files": [
    "bot.mjs",
    "lib/",
    ".env.example",
    "NOTICE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
