# Discord
DISCORD_TOKEN=
DISCORD_CHANNEL_IDS=
DISCORD_MODEL=anthropic/claude-sonnet-4-6

# Cloudflare (one token for chat + images; get from dash or `wrangler auth token`)
CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_AIG_GATEWAY_ID=skyphusion-llm
# Optional: override the compat URL; Anthropic chat uses the matching /anthropic path
# CF_GATEWAY_ENDPOINT=https://gateway.ai.cloudflare.com/v1/{account_id}/skyphusion-llm/compat/chat/completions

# Optional: persist conversation history across restarts
CF_D1_DATABASE_ID=

# Optional: web search + knowledge base (deploy search-worker first)
SEARCH_WORKER_URL=
SEARCH_SECRET=

# Optional: ollama fallback (omit CF_API_TOKEN to enable)
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# DISCORD_MODEL=qwen3:8b
